# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# playwright (e2e)
/test-results/
/playwright-report/
/playwright/.cache/
/playwright/.auth/
/blob-report/

# next.js
/.next/
/out/
.turbo

# production
/build

# misc — OS / OneDrive artifacts (this repo lives under OneDrive on Windows)
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.vscode

# AI assistant personal overrides (per-machine, never committed)
CLAUDE.local.md
GEMINI.local.md
.claude/settings.local.json

# Supabase CLI local state + build artifacts (per-machine, not source)
supabase/.temp/
tax-exports/

# Brainstorming visual-companion sessions (local scratch)
.superpowers/

# Development worklog — auto-updated per-machine journal, intentionally not tracked
# (persists on disk across terminal kills; update freely, no commits needed)
WORKLOG.md
