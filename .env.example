# ─── DigiOne — Environment Variables ─────────────────────────────────────
# Copy this file to .env.local and fill in the values.
# Never commit .env.local — it is in .gitignore.
# See .claude/rules/env-vars.md for full descriptions and where each is used.

# ── Supabase ─────────────────────────────────────────────────────────────
# Public values — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://qcendfisvyjnwmefruba.supabase.co  # set in local
NEXT_PUBLIC_SUPABASE_ANON_KEY=                                     # set in local

# Service role — server-only. Bypasses RLS. Never expose to the browser.
# Read by lib/supabase/service.ts and all /api/* routes via createServiceClient().
SUPABASE_SERVICE_KEY=                                              # set in local

# ── Cashfree (payments) ──────────────────────────────────────────────────
# Set CASHFREE_ENVIRONMENT to PRODUCTION to hit api.cashfree.com.
# Anything else (or unset) hits sandbox.cashfree.com.
CASHFREE_ENVIRONMENT=SANDBOX                                       # set in local
CASHFREE_CLIENT_ID=                                                # set in local
CASHFREE_CLIENT_SECRET=                                            # set in local
# (No NEXT_PUBLIC_ mirror — the browser SDK mode comes from the
# /api/checkout/create response's `environment` field.)

# ── App ──────────────────────────────────────────────────────────────────
# Absolute URL of this app. Used to build Cashfree return_url / notify_url
# and any other absolute links. No trailing slash.
NEXT_PUBLIC_APP_URL=http://localhost:3000                          # set in local

# Root domain for custom-domain detection in proxy.ts.
# Custom storefront domains that don't match this fall into /_custom/[domain]/* rewrite.
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000                             # set in local

# Dedicated short-link domain (bare-root redirector). No scheme, no trailing slash, no path.
# Must resolve to the SAME Vercel deployment as the main app — proxy.ts rewrites
# {domain}/{code} → /api/s/[code]. Leave unset to disable short-link routing.
NEXT_PUBLIC_SHORTLINK_DOMAIN=linkln.me                             # set in local

# ── Cloudflare R2 (object storage) ───────────────────────────────────────
# File storage. See .claude/todo-later/9(left)-2026-06-25-cloudflare-r2-storage-migration.md
# R2 is S3-compatible; read by src/lib/storage/r2.ts.
# Account ID: Cloudflare dashboard → R2 → "Account details".
R2_ACCOUNT_ID=                                                     # set in local

# API token credentials — server-only secrets. Never expose to the browser.
# Cloudflare dashboard → R2 → Manage R2 API Tokens → Create (Object Read & Write).
R2_ACCESS_KEY_ID=                                                  # set in local
R2_SECRET_ACCESS_KEY=                                              # set in local

# Bucket names (create these in R2). KYC is a dedicated, private, write-only bucket.
R2_BUCKET_KYC=digione-kyc-private                                  # set in local
R2_BUCKET_PRODUCTS=digione-products                                # set in local
R2_BUCKET_MEDIA=digione-media                                      # set in local
R2_BUCKET_PUBLIC=digione-public-assets                             # set in local

# Public base URLs for the two PUBLIC buckets (no trailing slash).
# Dev: use the bucket's r2.dev managed URL (R2 → bucket → Settings → Public access).
# Prod: map a custom domain (e.g. media.digione.ai) once digione.ai DNS is on Cloudflare.
NEXT_PUBLIC_R2_MEDIA_URL=https://media.digione.ai                  # set in local (r2.dev URL)
NEXT_PUBLIC_R2_BUCKET_PUBLIC_URL=https://assets.digione.ai         # set in local (r2.dev URL)

# Note: the S3 API endpoint is derived in code from R2_ACCOUNT_ID as
# https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com (default, no jurisdiction prefix).


# ── KYC (at-rest encryption) ─────────────────────────────────────────────
# Server-only. base64-encoded 32 bytes (AES-256) for KYC PII at-rest encryption. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
KYC_ENCRYPTION_KEY=                                                # set in local

# ── Cashfree Payouts (creator withdrawals) ────────────────────────────────
# SEPARATE from the PG (payment gateway) creds above — different Cashfree product.
# Set CASHFREE_PAYOUT_ENVIRONMENT to PRODUCTION to hit production Cashfree Payouts.
# Anything else (or unset) hits the sandbox environment.
CASHFREE_PAYOUT_ENVIRONMENT=SANDBOX                                # set in local
CASHFREE_PAYOUT_API_VERSION=2024-01-01                             # set in local
CASHFREE_PAYOUT_CLIENT_ID=                                         # in local, no value yet
CASHFREE_PAYOUT_CLIENT_SECRET=                                     # in local, no value yet
CASHFREE_PAYOUT_WEBHOOK_SECRET=                                    # in local, no value yet

# Secret shared by all cron-ready routes: /api/admin/payouts/sync (stuck-payout
# reconciliation), /api/instaauto/drain (DM queue drainer), and
# /api/instaauto/maintenance (stuck-message requeue + IG token refresh).
# Pass as Authorization: Bearer <CRON_SECRET> from your scheduler.
CRON_SECRET=                                                       # set in local

# DigiOne seller identity — on the DigiOne→creator commission tax invoice (Phase 6a). Server-only.
DIGIONE_LEGAL_NAME="DigiOne Technologies Pvt Ltd"                  # set in local
DIGIONE_GSTIN="27AAAAA0000A1Z5"                                    # set in local (placeholder value)
DIGIONE_PAN="AAAAA0000A"                                           # set in local (placeholder value)
DIGIONE_ADDRESS="Address line, City, PIN"                          # set in local (placeholder value)
DIGIONE_STATE="Maharashtra"                                        # set in local
DIGIONE_STATE_CODE="27"                                            # set in local

# ── Email (Resend) ───────────────────────────────────────────────────────
# Transactional email (purchase confirmations). Missing values = emails are
# silently skipped (dev-safe no-op). Verify the sending domain in the Resend
# dashboard (SPF/DKIM DNS records) before production.
RESEND_API_KEY=                                                    # set in local
EMAIL_FROM="DigiOne <receipts@digione.ai>"                         # set in local

# ── Instagram Auto DM ────────────────────────────────────────────────────
# Server-only. Meta app credentials for Instagram OAuth + webhook verification.
# INSTAGRAM_APP_ID unset → real OAuth connect disabled; demo accounts still work.
# Generate INSTAAUTO_TOKEN_ENCRYPTION_KEY: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
INSTAGRAM_APP_ID=                                                  # in local, no value yet
INSTAGRAM_APP_SECRET=                                              # in local, no value yet
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=                                    # set in local
INSTAAUTO_TOKEN_ENCRYPTION_KEY=                                    # set in local